# =============================================================================
# HGN SOS Alert Service - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# NEVER commit .env to version control (it's in .gitignore).
# =============================================================================

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hgn_sos
DB_USER=postgres
DB_PASSWORD=change_me_to_a_secure_password

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- MQTT Broker ---
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_CLIENT_ID=hgn-sos-backend

# --- JWT ---
# Generate with: openssl rand -base64 32
JWT_SECRET=replace_with_a_256bit_base64_secret
JWT_EXPIRATION_MS=86400000

# --- SOS Processing ---
DEDUP_TTL_SECONDS=60
ESCALATION_WINDOW_SECONDS=300
ESCALATION_POLL_MS=30000
RESOLUTION_GRACE_DAYS=1
